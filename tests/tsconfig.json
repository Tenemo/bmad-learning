{
  "extends": "../tsconfig.base.json",
  "compilerOptions": {
    "composite": true,
    "tsBuildInfoFile": "../node_modules/.cache/tests.tsbuildinfo",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "noEmit": true,
    "target": "ES2022",
    "types": [
      "node",
      "@playwright/test"
    ]
  },
  "include": [
    "./**/*.ts",
    "../playwright.config.ts"
  ]
}
